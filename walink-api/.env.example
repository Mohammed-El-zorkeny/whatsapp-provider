# ============================================================
# WaLink API — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# Express server port
PORT=3001

# 'development' | 'production'
NODE_ENV=development

# Supabase — use service_role key (bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# WAHA Docker instance (NOWEB engine)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your_waha_api_key

# Upstash Redis — for per-user sliding-window rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Salt used for webhook HMAC-SHA256 signature (any random string)
WEBHOOK_SECRET_SALT=your_random_salt_here
