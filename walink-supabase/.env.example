# ============================================================
# WaLink — Supabase Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# Your Supabase project URL
# Found at: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Public anon key — safe to expose in the frontend (Next.js)
# Found at: Supabase Dashboard → Project Settings → API → anon/public
SUPABASE_ANON_KEY=your_anon_key

# Private service role key — ONLY used in the Express backend (walink-api)
# This bypasses RLS — NEVER expose to the frontend or commit to git
# Found at: Supabase Dashboard → Project Settings → API → service_role/secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
